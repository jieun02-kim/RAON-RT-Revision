#	Copyright: ROBOGRAM LAB (2022)
##############################################################################

## COMMON
PROJ_ROOT_DIR=..
ROBOT_DIR=$(PROJ_ROOT_DIR)/CIIRobotRT
ECAT_DIR=$(PROJ_ROOT_DIR)/EMasterApp
PI_CONTROLLER_DIR=$(PROJ_ROOT_DIR)/PI_GCS2
EXAMPLES_DIR==$(PROJ_ROOT_DIR)/Examples
GLOBAL_DIR=$(PROJ_ROOT_DIR)/Global

## THIS
THIRD_PARTY_DIR=/opt
#THIRD_PARTY_DIR=$(ECAT_DIR)/ThirdParty
DEVICE_DIR=$(ECAT_DIR)/Device
IFACE_DIR=$(ECAT_DIR)/Interface
IGH_DIR=$(THIRD_PARTY_DIR)/etherlab

#THIS
#RT_POSIX_DIR=$(GLOBAL_DIR)/ThirdParty/rt_posix
RT_POSIX_DIR=$(THIRD_PARTY_DIR)/rt_posix
RT_POSIX_INCLUDE=$(RT_POSIX_DIR)/include
RT_POSIX_LIB=$(RT_POSIX_DIR)/lib

#CFLAGS AND LDFLAGS
CFLAGS_OPTIONS = -Wall -O3 -mtune=native -flto
CFLAGS = $(CFLAGS_OPTIONS) -I$(DEVICE_DIR) -I$(GLOBAL_DIR) -I$(IGH_DIR)/include -I$(RT_POSIX_INCLUDE)

LDFLAG_IGH = -L$(IGH_DIR)/lib -lethercat
LDFLAG_RT_POSIX = -L$(RT_POSIX_LIB) -lrtposix
LDFLAGS = -lm -lrt -lpthread $(LDFLAG_IGH) $(LDFLAG_RT_POSIX)


#SOURCES
SOURCES	+= $(DEVICE_DIR)/EcatMasterBase.cpp
SOURCES	+= $(DEVICE_DIR)/EcatSlaveBase.cpp
SOURCES	+= $(DEVICE_DIR)/SlaveCIA402Base.cpp
SOURCES	+= $(DEVICE_DIR)/SlaveNRMKEndTool.cpp

#OUTPUT
CC=g++
OBJECT_DIR=$(ECAT_DIR)/obj
OUTPUT_DIR=$(ECAT_DIR)/lib
LIBRARY_OUT=libEMasterApp

#INSTALL DIRECTORY
INSTALL_DIR := $(PROJ_ROOT_DIR)


#######################################################################################################
OBJECTS = $(addprefix $(OBJECT_DIR)/, $(notdir $(patsubst %.cpp, %.o, $(SOURCES))))
#######################################################################################################
vpath %.cpp  $(DEVICE_DIR)
#######################################################################################################


all: shared_object static_object

install: shared_object static_object
	@echo COPYING OBJECTS TO $(INSTALL_DIR)/
	@ mkdir -p $(INSTALL_DIR)/include/EMasterApp; pwd > /dev/null
	cp -rfp $(DEVICE_DIR)/*.h $(INSTALL_DIR)/include/EMasterApp
	@ mkdir -p $(INSTALL_DIR)/lib/EMasterApp; pwd > /dev/null
	cp -rfp $(OUTPUT_DIR)/* $(INSTALL_DIR)/lib/EMasterApp

re:
	make clean
	make
	make install

static_object: $(OUTPUT_DIR)/$(LIBRARY_OUT).a
$(OUTPUT_DIR)/$(LIBRARY_OUT).a: $(OBJECTS)
	@echo -n "GENERATING STATIC OBJECT..."
	ar rc $@ $(OBJECTS)
	ranlib $@
	@echo "DONE!"


shared_object: $(OUTPUT_DIR)/$(LIBRARY_OUT).so
$(OUTPUT_DIR)/$(LIBRARY_OUT).so: $(OBJECTS)
	@echo -n "GENERATING SHARED OBJECT..."
	@ mkdir -p $(OUTPUT_DIR); pwd > /dev/null
	$(CC) -g -shared $(CFLAGS) -o $@ -fPIC $(OBJECTS) $(LDFLAGS)
	@echo "DONE!"

objects: $(OBJECTS)
$(OBJECT_DIR)/%.o : %.cpp
	@echo "GENERATING SOURCE OBJECTS..."
	@mkdir -p $(OBJECT_DIR); pwd > /dev/null
	$(CC) -MD $(CFLAGS) -c -g -o $@ $<

clean:	
	@echo -n "CLEANING..."
	@if [ -d $(OBJECT_DIR) ]; then rm -rf $(OBJECT_DIR); fi
	@if [ -d $(OUTPUT_DIR) ]; then rm -rf $(OUTPUT_DIR); fi
	@echo "DONE!"

distclean: clean

.PHONY: all clean 
##############################################################################
# Include header file dependencies generated by -MD option:
-include $(OBJECT_DIR)/*.d
